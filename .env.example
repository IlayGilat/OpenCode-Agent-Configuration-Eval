# Path to the repository that OpenCode should edit and evaluate.
REPO_PATH=./sample-repo

# Directory where run artifacts, patches, and reports will be written.
RUNS_PATH=./runs

# OpenCode model identifier used for both solver and judge phases.
MODEL=opencode/deepseek-v4-flash-free

# Max time allowed for each OpenCode invocation, in milliseconds.
TIMEOUT_MS=3600000

# Optional: uncomment to force a stable run folder name.
# Leave unset to let the CLI generate a timestamped run name.
# CONFIGURED_RUN_NAME=my-local-eval
